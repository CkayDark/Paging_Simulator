# target to build an object file
tlb.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Paging_Simulator.dir/build.make CMakeFiles/Paging_Simulator.dir/tlb.cpp.o
.PHONY : tlb.cpp.o

tlb.i: tlb.cpp.i
.PHONY : tlb.i

